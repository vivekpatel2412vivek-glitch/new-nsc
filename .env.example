# Copy this file to .env and fill in real values. Never commit .env.

# Required - Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Required once this dashboard is reachable by anyone but you (shared
# network, or a public deployment like Render) - gates every route with
# HTTP Basic Auth. If DASHBOARD_PASSWORD is left blank, a random one is
# generated at startup and printed to the log instead.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=vivek@2412

# Optional overrides
GEMINI_MODEL=gemini-flash-latest
NSE_SYMBOL=NIFTY
STRIKE_STEP=50
STRIKES_AROUND_ATM=10
TOP_N_LEVELS=3
TOP_N_MOVERS=8
NIFTY_LOT_SIZE=65
CONVICTION_PERCENTILE=0.25

# Paper portfolio framing (Rs) for ledger.py and the Gemini strategist persona.
PORTFOLIO_CAPITAL=2500000
PROFIT_TARGET=200000

# Local server bind (dashboard.py - opens at http://<host>:<port>).
# Render/Railway inject PORT automatically and override DASHBOARD_PORT.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
