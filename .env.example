# Copy this file to .env and fill in real values. Never commit .env.

# Required - Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Not required for the default data source (nse_client.py uses NSE's public
# option-chain endpoint - no account needed). Only fill these in if you swap
# nse_client.py's get_option_chain() to call a real broker (Kite Connect /
# Upstox / Angel One / other) instead.
NSE_BROKER_API_KEY=
NSE_BROKER_API_SECRET=
NSE_BROKER_ACCESS_TOKEN=

# Optional overrides
GEMINI_MODEL=gemini-flash-latest
NSE_SYMBOL=NIFTY
EXPIRY_MODE=weekly
STRIKE_STEP=50
STRIKES_AROUND_ATM=10
TOP_N_LEVELS=3
TOP_N_MOVERS=8
NIFTY_LOT_SIZE=65
CONVICTION_PERCENTILE=0.25

# Paper portfolio framing (Rs) for ledger.py and the Gemini strategist persona.
PORTFOLIO_CAPITAL=2500000
PROFIT_TARGET=200000

# Automation loop (main.py runs continuously by default - see --once to run
# a single cycle instead). Market hours are in IST regardless of host TZ.
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
CYCLE_INTERVAL_SECONDS=300

# Dashboard (python dashboard.py - opens at http://<host>:<port>). Read-only
# view of the same data/ folder main.py writes to; run both at once, each in
# their own terminal.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
